{
  "entities": {
    "AirServiceRecord": {
      "title": "AirServiceRecord",
      "description": "Record of an air machine service",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "vehicleType": { "type": "string", "enum": ["Pikipiki", "Gari", "Bajaj", "Baiskeli"] },
        "count": { "type": "number" },
        "price": { "type": "number" },
        "total": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "paymentMethod": { "type": "string" },
        "notes": { "type": "string" },
        "uid": { "type": "string" }
      },
      "required": ["id", "vehicleType", "count", "price", "total", "date", "paymentMethod", "uid"]
    },
    "Layaway": {
      "title": "Layaway",
      "description": "Record of a layaway purchase",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "name": { "type": "string" },
              "quantity": { "type": "number" },
              "unitPrice": { "type": "number" }
            }
          }
        },
        "totalAmount": { "type": "number" },
        "amountPaid": { "type": "number" },
        "remainingBalance": { "type": "number" },
        "payments": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "date": { "type": "string", "format": "date-time" },
              "amount": { "type": "number" },
              "method": { "type": "string" }
            }
          }
        },
        "startDate": { "type": "string", "format": "date-time" },
        "deadlineDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["ACTIVE", "COMPLETED", "CANCELLED"] },
        "notes": { "type": "string" },
        "uid": { "type": "string" }
      },
      "required": ["id", "customerName", "items", "totalAmount", "amountPaid", "remainingBalance", "startDate", "deadlineDate", "status", "uid"]
    }
  },
  "firestore": {
    "air_services/{serviceId}": {
      "schema": "AirServiceRecord",
      "description": "Air machine service records"
    },
    "layaways/{layawayId}": {
      "schema": "Layaway",
      "description": "Layaway purchase records"
    }
  }
}
